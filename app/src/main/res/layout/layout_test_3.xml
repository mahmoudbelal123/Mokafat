<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <android.support.v7.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="@color/pastelgray"
        app:cardElevation="6dp"
        app:cardMaxElevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0">
        <TextView
            android:textSize="16sp"
            android:textStyle="normal"
            android:textColor="@color/brickred"
            android:gravity="start|center_vertical"
            android:id="@+id/textView37"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="15dp"
            android:text="Details"
            android:textAllCaps="true"/>
    </android.support.v7.widget.CardView>
    <TextView
        android:textColor="@color/darkgray"
        android:gravity="start|center_vertical"
        android:id="@+id/textView_Details"
        android:background="@color/white"
        android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nam vitae sapien ut neque sodales luctus a id nibh. Sed non congue mi, in aliquam odio. Donec sollicitudin sem ac augue lobortis pellentesque. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Curabitur a dui ut massa tempor volutpat sed a tellus."/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/linear_find_partner"
        android:background="@color/brickred"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="30dp">
        <ImageView
            android:gravity="start|center_vertical"
            android:id="@+id/textView38"
            android:paddingLeft="100dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="15dp"
            android:src="@drawable/map_marker"
            android:layout_weight="1.7"/>
        <TextView
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="start|center_vertical"
            android:padding="5dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Find the Partner"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
