<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:background="@drawable/splash_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_weight="3">
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/start_tour"
        android:layout_weight="2.4"/>
    <Button
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:id="@+id/button_start_tour"
        android:background="@drawable/button"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="30dp"
        android:layout_marginRight="30dp"
        android:text="@string/start_the_tour"
        android:layout_weight="0.3"
        android:textAllCaps="false"/>
    <TextView
        android:textSize="17sp"
        android:textStyle="normal"
        android:textColor="@color/liver"
        android:gravity="end"
        android:id="@+id/textView_skip_to_sign_in"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="30dp"
        android:layout_marginTop="14dp"
        android:layout_marginRight="32dp"
        android:text="@string/start_the_tour_Skip"
        android:layout_weight="0.3"/>
</LinearLayout>
