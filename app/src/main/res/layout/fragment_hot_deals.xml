<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ProgressBar
        android:layout_gravity="top|center_horizontal"
        android:id="@+id/progressbar_subsection_loading"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/imageView_section_"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="0dp"
                android:scaleType="centerCrop"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/imageView3"
                android:background="#66000000"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="100dp"
                app:layout_constraintBottom_toBottomOf="@+id/imageView_section_"
                app:layout_constraintEnd_toEndOf="@+id/imageView_section_"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toStartOf="@+id/imageView_section_"
                app:layout_constraintTop_toTopOf="@+id/imageView_section_"
                app:layout_constraintVertical_bias="1">
                <TextView
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:id="@+id/textView11_section_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:text="title"
                    app:layout_constraintVertical_bias="0"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp">
                    <TextView
                        android:textStyle="bold"
                        android:textColor="@color/brickred"
                        android:id="@+id/textView16_vendors"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        app:layout_constraintVertical_bias="1"/>
                    <TextView
                        android:textStyle="bold"
                        android:textColor="@color/darkgray"
                        android:id="@+id/textView17"
                        android:padding="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vendors"
                        app:layout_constraintVertical_bias="1"/>
                    <TextView
                        android:textStyle="bold"
                        android:textColor="@color/pearlaqua"
                        android:id="@+id/textView18_offers"
                        android:padding="1dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""/>
                    <TextView
                        android:textStyle="bold"
                        android:textColor="@color/darkgray"
                        android:id="@+id/textView19_offers"
                        android:padding="1dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Offers"/>
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>
        <androidx.cardview.widget.CardView
            android:id="@+id/cardView"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            app:cardBackgroundColor="@color/brickred"
            app:cardMaxElevation="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.recyclerview.widget.RecyclerView
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:id="@+id/picker"
                android:scrollbars="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textDirection="rtl"
                android:layoutDirection="ltr"/>
        </androidx.cardview.widget.CardView>
        <FrameLayout
            android:id="@+id/framelayout_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="5dp">
            <include layout="@layout/fragment_get_items"/>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
