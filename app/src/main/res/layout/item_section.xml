<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="5dp"
    android:layout_width="180dp"
    android:layout_height="180dp">
    <ImageView
        android:id="@+id/imageView_section"
        android:background="@drawable/education"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp"
        android:scaleType="centerCrop"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"/>
    <ImageView
        android:layout_gravity="bottom"
        android:id="@+id/imageView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp"
        android:layout_marginStart="0dp"
        app:srcCompat="@drawable/section_title_bg_test"/>
    <TextView
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_gravity="bottom"
        android:id="@+id/textView11_section_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="title"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/imageView3"
        app:layout_constraintEnd_toEndOf="@+id/imageView3"
        app:layout_constraintHorizontal_bias="0.075"
        app:layout_constraintStart_toStartOf="@+id/imageView3"
        app:layout_constraintTop_toTopOf="@+id/imageView3"
        app:layout_constraintVertical_bias="0"/>
    <LinearLayout
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:layout_width="170dp"
        android:layout_height="20dp"
        android:layout_margin="5dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/imageView3"
        app:layout_constraintEnd_toEndOf="@+id/imageView3"
        app:layout_constraintStart_toStartOf="@+id/imageView3"
        app:layout_constraintTop_toTopOf="@+id/imageView3">
        <TextView
            android:textStyle="bold"
            android:textColor="@color/brickred"
            android:id="@+id/textView16_vendors"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:text="1000"/>
        <TextView
            android:textStyle="bold"
            android:textColor="@color/darkgray"
            android:id="@+id/textView17"
            android:padding="1dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vendors,"/>
        <TextView
            android:textStyle="bold"
            android:textColor="@color/pearlaqua"
            android:id="@+id/textView18_offers"
            android:padding="1dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1000"/>
        <TextView
            android:textStyle="bold"
            android:textColor="@color/darkgray"
            android:id="@+id/textView19"
            android:padding="1dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Offers"/>
    </LinearLayout>
</FrameLayout>
