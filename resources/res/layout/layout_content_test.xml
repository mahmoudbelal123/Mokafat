<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="1dp"
    app:cardBackgroundColor="@color/whitesmoke_2"
    app:cardMaxElevation="3dp">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="17sp"
            android:textColor="@color/ashgrey_2"
            android:gravity="center"
            android:id="@+id/text_section"
            android:padding="15dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="title"
            android:layout_weight="0.12"/>
        <ToggleButton
            android:gravity="center"
            android:id="@+id/toggle_button_section"
            android:background="@drawable/selector_section_toggle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:textOn=""
            android:textOff=""
            android:layout_weight="0.88"
            android:contentDescription="test"/>
    </LinearLayout>
</android.support.v7.widget.CardView>
