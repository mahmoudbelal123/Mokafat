<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/splash_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:background="@drawable/forget_password_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="58dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textSize="19sp"
        android:textStyle="bold"
        android:textColor="@color/davygrey"
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="137dp"
        android:text="Forgot your password"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textSize="15sp"
        android:textStyle="normal"
        android:textColor="@color/taupegray"
        android:gravity="center"
        android:id="@+id/textView4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="24dp"
        android:layout_marginTop="189dp"
        android:layout_marginRight="24dp"
        android:text="We just need your registered mobile number to send you password reset instructions"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="255dp">
        <EditText
            android:textColorHint="@color/white"
            android:id="@+id/editText"
            android:background="@drawable/sign_in_text_box"
            android:padding="10dp"
            android:layout_width="298dp"
            android:layout_height="50dp"
            android:hint="Mobile/ Email"
            android:ems="10"
            android:drawableLeft="@drawable/mobile_icon"
            android:drawablePadding="20dp"
            android:inputType="textEmailAddress"/>
        <Button
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/button_reset_password"
            android:background="@drawable/button"
            android:layout_width="296dp"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:text="Reset Password"
            android:textAllCaps="false"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/liver"
            android:gravity="start"
            android:id="@+id/textView_forget_password"
            android:padding="10dp"
            android:layout_width="296dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/back"/>
    </LinearLayout>
</RelativeLayout>
